import tkinter as tk
import random

skaitlis = random.randint(1, 100)

def minet():
    try:
        lietotaja = int(entry.get())

        if lietotaja < skaitlis:
            rezultats.config(text="Par mazu!")
        elif lietotaja > skaitlis:
            rezultats.config(text="Par lielu!")
        else:
            rezultats.config(text="Pareizi! Tu uzvarēji!")

    except:
        rezultats.config(text="Ievadi skaitli!")


logs = tk.Tk()
logs.title("Minēšanas spēle")

teksts = tk.Label(logs, text="Uzmini skaitli (1–100)", font=("Verdana", 20))
teksts.pack(pady=20)

entry = tk.Entry(logs, font=("Verdana", 18))
entry.pack(pady=10)

poga = tk.Button(
    logs,
    text="Minēt",
    font=("Verdana", 16),
    command=minet
)
poga.pack(pady=10)

rezultats = tk.Label(logs, text="", font=("Verdana", 18))
rezultats.pack(pady=20)

logs.mainloop()
